# Project — traces and logs
# Ignore everything in traces/ (raw traces may contain PII from personal
# trees) EXCEPT the redacted/ subdir, which holds pseudonymized traces
# safe to commit as demonstration artifacts. The .map.json mapping files
# MUST stay local — they re-identify real people.
traces/*
# Pseudonymized traces from personal trees — safe to commit
!traces/redacted/
traces/redacted/*.map.json
# Public-data demo traces (Kennedy, Habsburg, Queen) — safe to commit as-is
!traces/demos/
*.log

# Deprecated migration-map PoC
# Preserved on the feature/migration-map branch on origin; not part of
# the main project scope.
app/
data/geodata/

# ---------------------------------------------------------------
# PII — personal genealogical data. NEVER commit.
# ---------------------------------------------------------------
# Personal GEDCOM files
data/PII Trees/
# DNA match exports (MyHeritage, GEDmatch, AncestryDNA, etc.)
data/DNA/
data/dna/
# eval/results/ contains a mix of public-data and PII-bearing JSON.
# Default to ignored; allow-list ONLY result-file patterns whose name
# explicitly identifies a public-data subject (jfk / tier1 / tier2 /
# tier3 / kennedy / habsburg / queen / victoria), plus the deterministic
# *.md summary files. Date-only patterns are NOT allow-listed because
# real-tree work has shared dates with public-data work.
#
# Explicit deny rules at the bottom block any *moore* / *Moore* / *Smith*
# / *McCusker* file regardless of pattern (last-match-wins).
eval/results/*
!eval/results/*.md
!eval/results/eval_*.json
!eval/results/isolation_*.json
!eval/results/ablation_*.json
!eval/results/*_jfk.json
!eval/results/*_jfk_*.json
!eval/results/*_kennedy.json
!eval/results/*_kennedy_*.json
!eval/results/*_tier[123].json
!eval/results/*_tier[123]_*.json
!eval/results/*_habsburg.json
!eval/results/*_habsburg_*.json
!eval/results/*_queen.json
!eval/results/*_queen_*.json
!eval/results/*_victoria.json
!eval/results/*_victoria_*.json
# Last-match-wins denies for personal-tree subjects.
eval/results/*moore*
eval/results/*Moore*
eval/results/*smith*
eval/results/*Smith*
eval/results/*mccusker*
eval/results/*McCusker*
